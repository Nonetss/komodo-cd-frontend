# ─── Better Auth ─────────────────────────────────────────────────────────────
# URL base que usa el cliente de better-auth para llamar a /api/auth/*.
# En producción: la URL pública del servidor (ej. https://app.example.com)
# Se hornea en el bundle en tiempo de build.
BETTER_AUTH_URL="http://localhost:4321"

# ─── URL pública (embebida en el bundle) ─────────────────────────────────────
# Se muestra en los snippets curl del dashboard.
# Si no se define en build time, el cliente usa window.location.origin como fallback.
PUBLIC_APP_URL="http://localhost:4321"

# ─── Backend — sólo para Nginx (Docker) ──────────────────────────────────────
# URL interna al contenedor backend. Nginx la usa para hacer proxy de /api/*.
# No se expone al navegador. Por defecto apunta al servicio "backend" del compose.
BACKEND_URL="http://backend:3000"
