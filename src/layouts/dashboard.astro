---
import Main from './main.astro';
import { ButtonLogOut } from '@/components/features/login/buttonLogOut';
import { LanguageSwitcher } from '@/components/LanguageSwitcher';

const { title = 'Komodo CD' } = Astro.props;
const { user } = Astro.locals;

const lang = (Astro.cookies.get('lang')?.value ?? 'es') as 'es' | 'en';

const NAV_LABELS = {
  es: {
    stacks: 'Stacks',
    history: 'Historial',
    deploy: 'Deploy',
    credentials: 'Credenciales',
    apikeys: 'API Keys',
  },
  en: {
    stacks: 'Stacks',
    history: 'History',
    deploy: 'Deploy',
    credentials: 'Credentials',
    apikeys: 'API Keys',
  },
};

const labels = NAV_LABELS[lang] ?? NAV_LABELS.es;

const NAV = [
  { href: '/stacks', label: labels.stacks },
  { href: '/history', label: labels.history },
  { href: '/deploy', label: labels.deploy },
  { href: '/credentials', label: labels.credentials },
  { href: '/keys', label: labels.apikeys },
];

const path = Astro.url.pathname;
---

<Main title={`${title} — Komodo CD`}>
  <div class="flex min-h-screen flex-col">
    <header class="bg-card/60 sticky top-0 z-50 backdrop-blur-md">
      <div class="mx-auto max-w-5xl px-4 sm:px-6">
        <div
          class="flex min-h-14 flex-wrap items-center gap-x-4 gap-y-2 py-2 sm:flex-nowrap sm:gap-6 sm:py-0"
        >
          <!-- Brand -->
          <a href="/stacks" class="group flex shrink-0 items-center gap-2">
            <img
              src="/logo.svg"
              alt=""
              aria-hidden="true"
              class="h-6 w-auto opacity-90 transition-opacity group-hover:opacity-100"
            />
            <span
              class="text-foreground group-hover:text-primary text-sm font-semibold tracking-tight transition-colors"
              >Komodo CD</span
            >
          </a>

          <!-- Divider -->
          <div class="bg-border hidden h-5 w-px shrink-0 sm:block"></div>

          <!-- Nav links -->
          <nav
            class="order-3 -mx-1 flex w-full items-center gap-1 overflow-x-auto pb-1 sm:order-0 sm:mx-0 sm:w-auto sm:min-w-0 sm:flex-1 sm:overflow-visible sm:pb-0"
          >
            {
              NAV.map((item) => {
                const isActive =
                  path === item.href || path.startsWith(item.href + '/');
                return (
                  <a
                    href={item.href}
                    class={`rounded-md px-3 py-1.5 text-sm font-medium whitespace-nowrap transition-colors ${
                      isActive
                        ? 'bg-primary/10 text-primary'
                        : 'text-muted-foreground hover:text-foreground hover:bg-accent'
                    }`}
                  >
                    {item.label}
                  </a>
                );
              })
            }
          </nav>

          <!-- User -->
          <div
            class="ml-auto flex shrink-0 items-center gap-2 sm:ml-0 sm:gap-3"
          >
            <span
              class="text-muted-foreground hidden max-w-[160px] truncate text-xs lg:block"
            >
              {user?.email}
            </span>
            <LanguageSwitcher client:only="react" />
            <ButtonLogOut client:only="react" />
          </div>
        </div>
      </div>
      <!-- gradient separator line -->
      <div
        class="from-primary/0 via-primary/20 to-primary/0 h-px bg-linear-to-r"
      >
      </div>
    </header>

    <main class="mx-auto w-full max-w-5xl flex-1 px-4 py-5 sm:px-6 sm:py-8">
      <slot />
    </main>
  </div>
</Main>
