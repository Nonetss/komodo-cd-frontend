---
import Main from '@/layouts/main.astro';
import { ButtonLogOut } from '@/components/features/login/buttonLogOut';
import { Dashboard } from '@/components/features/dashboard/Dashboard';
const { user } = Astro.locals;
---

<Main title="Komodo Dashboard">
  <div class="min-h-screen bg-white font-sans text-black">
    <header class="flex items-center justify-between border-b px-8 py-4">
      <h1 class="text-xl font-bold">Komodo</h1>
      <div class="flex items-center gap-4">
        <span class="text-sm text-slate-500">{user?.email}</span>
        <ButtonLogOut client:only="react" />
      </div>
    </header>
    <main class="mx-auto max-w-5xl p-8">
      <Dashboard client:only="react" />
    </main>
  </div>
</Main>
